# Application
APP_NAME=Semantic Omni Search Engine
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://search_user:search_pass@postgres:5432/search_db

# File storage
UPLOAD_DIR=/app/uploads
FAISS_INDEX_DIR=/app/faiss_index
MAX_UPLOAD_SIZE_MB=500

# Embedding models
TEXT_MODEL=all-MiniLM-L6-v2
CLIP_MODEL=openai/clip-vit-base-patch32
WHISPER_MODEL=base

# Search defaults
TOP_K=10
SIMILARITY_THRESHOLD=0.0

# Observability
PROMETHEUS_ENABLED=true

# CORS (comma-separated for multiple origins, or * for all)
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=*
